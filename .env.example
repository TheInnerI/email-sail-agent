# Email Sail Agent — Environment Variables
# Copy to .env and fill in your values

# Flask/FastAPI
SECRET_KEY=change-me-to-a-random-secret-key
SESSION_COOKIE_NAME=email_sail_session

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8090/auth/callback

# Twilio — https://console.twilio.com
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Gumroad — https://gumroad.com/settings/advanced#application_form
GUMROAD_API_KEY=your-gumroad-api-key

# PoA Engine (optional, for receipts)
POA_ENGINE_URL=http://localhost:8000

# MIO Observer (optional, for residual tracking)
MIO_OBSERVER_URL=http://localhost:8787

# OpenRouter (AI email drafts) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=openrouter/auto

# Database
DATABASE_PATH=data/email_sail.db

# App
APP_HOST=0.0.0.0
APP_PORT=8090
APP_DEBUG=false
