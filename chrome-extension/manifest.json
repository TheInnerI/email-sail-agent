{
    "manifest_version": 3,
    "name": "Email Sail Agent",
    "version": "1.0.0",
    "description": "⛵ Your email command center. Sort, draft, book, text, and retain revenue.",
    "permissions": [
        "storage",
        "activeTab",
        "identity"
    ],
    "host_permissions": [
        "https://mail.google.com/*",
        "http://localhost:8090/*",
        "https://email-sail.innerinetcompany.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Email Sail Agent"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["https://mail.google.com/*"],
            "js": ["content.js"],
            "css": []
        }
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
